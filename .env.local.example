# Supabase — preencha com os valores do seu projeto em https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# URL base do site (usada em redirects de OAuth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# AI Suite — chaves para as ferramentas de IA
# ============================================================

# Anthropic Claude — usado pelo Auto B-Roll (geracao de prompts de cena)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# AssemblyAI — transcricao com timestamps por palavra (Troca de Produto)
# https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# ElevenLabs — clonagem de voz + TTS (Troca de Produto)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# (Opcional) Replicate — Demucs para separacao de trilha musical/voz
# antes da clonagem, quando o audio tem musica de fundo.
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
