# Supabase — preencha com os valores do seu projeto em https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (admin) — usado pelo middleware pra ler profiles bypass RLS
# e pra criar usuarios em /admin. NUNCA exponha no client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL base do site (usada em redirects de OAuth e anti-clone)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# CLI / MCP — controle server-to-server do app (o `autoedit` CLI)
# ============================================================
# Chave-mestra de máquina. Quem tiver ela controla o app inteiro pela API
# (tier admin), SEM cookie de browser. DESLIGADO por padrão: sem esta var
# (ou com chave < 24 chars) o caminho de auth de máquina fica inerte e nada
# muda no app. Gera uma forte: openssl rand -hex 32  (ou: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Setar AQUI e no ambiente da Vercel (Production). O CLI manda no header x-autoedit-key.
AUTOEDIT_CLI_KEY=
# (Opcional) user id real do dono no Supabase, pra atribuir uploads/jobs do CLI
# a uma conta de verdade. Se vazio, usa o id sintético 'autoedit-cli'.
AUTOEDIT_CLI_USER_ID=
# (Opcional) email exibido pra identidade de máquina (default cli@darkoautoedit.com)
AUTOEDIT_CLI_EMAIL=

# Encryption key pras chaves de IA dos usuarios (BYOK).
# Gera 32 bytes random e poe em hex. Ex: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=

# ============================================================
# Stripe — pagamento ÚNICO por período (cartão/PIX/boleto, sem recorrência)
# ============================================================
# Os valores (R$ 57/116 mensal, R$ 540/1104 anual) ficam no código
# (lib/plan-prices.ts, price_data inline) — não precisa de Price IDs.
# Habilite PIX e boleto em: Stripe > Settings > Payment methods.
#
# Chave secreta da API. Test: sk_test_...  Prod: sk_live_...
STRIPE_SECRET_KEY=
# Chave publicável (pk_test_/pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Signing secret do webhook (Developers > Webhooks > seu endpoint).
# Endpoint = https://SEU-DOMINIO/api/billing/webhook  (whsec_...)
STRIPE_WEBHOOK_SECRET=

# ============================================================
# Mind Ads — modelos default (opcional, override via UI)
# ============================================================

# Modelo de imagem default (sobrescreve o tier eco)
# MIND_ADS_IMAGE_MODEL=black-forest-labs/flux-schnell

# Modelo de video default
# MIND_ADS_VIDEO_MODEL=kwaivgi/kling-v1.6-standard

# ============================================================
# Notas BYOK
# ============================================================
#
# As chaves de IA listadas abaixo sao APENAS pra desenvolvimento local
# OU como fallback. Em producao, cada usuario configura suas proprias
# chaves em /configuracoes/api (cifradas com AES-256-GCM via
# SECRETS_ENCRYPTION_KEY acima).
#
# Servicos suportados no BYOK:
#   - Anthropic (Claude)        — Auto B-Roll, Mind Ads, Take Splitter IA
#   - AssemblyAI                 — Mind Ads premium, Decupagem fallback
#   - ElevenLabs                 — Troca de Produto
#   - HeyGen                     — Mind Ads (avatar) + Auto Avatar
#   - Replicate                  — Mind Ads (b-rolls)
#   - Groq                       — Whisper barato (Decupagem v2 default)

# ============================================================
# Chaves dev/fallback (opcional)
# ============================================================

# ============================================================
# LTX-Video 2.3 — Hugging Face ZeroGPU (geração unlimited)
# ============================================================
# Proxy server-side autenticado (@gradio/client) pra Space oficial
# Lightricks/LTX-2-3 (H200, ZeroGPU). O ZeroGPU EXIGE auth — raw REST/
# anônimo NÃO funciona. A Space reserva 75s de GPU por chamada.
#
# Pool de ATÉ 30 contas. Quota é POR CONTA HF, não por token (cada token
# DEVE vir de uma conta HF DIFERENTE; tokens da mesma conta = mesma
# quota). Separe por vírgula — rotação automática (LRU + respeita o
# cooldown que o HF manda + jitter anti-rajada). Status/previsibilidade
# em /api/ltx-video/status (só admin).
#   Free: ~5 min GPU/dia/conta  -> ~4 vídeos/dia por conta
#   PRO : ~25 min GPU/dia/conta -> ~20 vídeos/dia por conta
# Ex (30 contas): HF_TOKENS=hf_c1,hf_c2,...,hf_c30
HF_TOKENS=
# Se o pool for de contas PRO, ajuste a estimativa de gerações/conta/dia
# (default 4, que é o de conta free). Ex p/ PRO: LTX_GENS_PER_ACCOUNT=20
LTX_GENS_PER_ACCOUNT=

ANTHROPIC_API_KEY=
ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=
REPLICATE_API_TOKEN=
HEYGEN_API_KEY=
GROQ_API_KEY=

# ============================================================
# Fal.ai — upload público do LipSync (fal.storage) + LatentSync legado
# ============================================================
FAL_KEY=

# ============================================================
# DreamFace — LipSync ILIMITADO (API privada do app web, conta paga)
# ============================================================
# /tools/lipsync (admin-only) roda na conta consumer paga do DreamFace,
# server-to-server, SEM créditos por geração (Avatar Video lipsync não
# consome créditos = "ilimitado" pelo custo fixo da conta).
#
# AUTH: NÃO precisa de cookie nem token! VERIFICADO que os endpoints do
# pipeline autorizam SÓ pelo account_id/user_id no corpo (credentials:'omit'
# retorna 200/THS). Sem expiração — durável pra sempre. Só preencha os 2 IDs
# (pegue do corpo de qualquer request /dw-server/* no DevTools > Network):
DREAMFACE_ACCOUNT_ID=
DREAMFACE_USER_ID=
# Opcionais (têm default no código):
# DREAMFACE_APP_VERSION=4.7.1
# DREAMFACE_TEMPLATE_ID=6606889f54e4e700070db4b1
# Opcionais e NÃO necessários (só future-proof se a API um dia exigir auth):
# DREAMFACE_COOKIE=
# DREAMFACE_TOKEN=
#
# >>> ANTI-BLOQUEIO (IMPORTANTE em produção / Vercel) <<<
# A Vercel sai por MUITOS IPs de datacenter. 1 cookie batendo de N IPs
# parece conta compartilhada e arrisca bloqueio. Roteie TODAS as chamadas
# DreamFace por UM proxy de IP FIXO (HTTP CONNECT) — aí o DreamFace só vê
# 1 IP, indistinguível de um usuário normal. Ex: http://user:pass@ip:porta
# DREAMFACE_PROXY_URL=
# Ritmo humano (por CONTA, por instância):
# DREAMFACE_CONCURRENCY=2          # = gerações simultâneas POR conta
# DREAMFACE_MIN_GAP_MS=800         # gap mínimo entre inícios (anti-rajada)
#
# >>> POOL DE VÁRIAS CONTAS (distribuição inteligente + failover) <<<
# Pra escalar e nunca depender de 1 conta só: liste VÁRIAS contas num JSON.
# O sistema distribui a carga (escolhe a menos ocupada), roda em PARALELO
# (N contas = N lipsyncs ao mesmo tempo) e faz FAILOVER automático (se uma
# conta cai por cookie/IP, tenta a próxima sozinho e tira a morta do rodízio).
# Se DREAMFACE_ACCOUNTS existir, ele MANDA (os envs únicos acima viram fallback).
# Campos por conta: accountId+userId (obrig.); cookie, token, proxyUrl,
# appVersion, templateId (opcionais — herdam os defaults/globais acima).
# IDEAL: 1 proxyUrl (IP fixo) por conta, pra cada cookie sair sempre do mesmo IP.
# DREAMFACE_ACCOUNTS=[{"label":"c1","accountId":"...","userId":"...","cookie":"...","proxyUrl":"http://user:pass@ip1:porta"},{"label":"c2","accountId":"...","userId":"...","cookie":"...","proxyUrl":"http://user:pass@ip2:porta"}]
# Tunables do pool (opcionais):
# DREAMFACE_MAX_PER_ACCOUNT=2      # sobrepõe o CONCURRENCY pro pool
# DREAMFACE_COOLDOWN_MS=300000     # quanto uma conta que falhou auth fica fora (5min)
# DREAMFACE_MAX_WAIT_MS=90000      # espera por vaga quando todas ocupadas

# ============================================================
# vmake.ai — Removedor de Legenda/Marca d'Água SMART (admin-only)
# ============================================================
# /tools/remover-elementos (admin-only) roda na conta paga do vmake (Vmake
# Labs / Meitu), server-to-server, SEM instalador e SEM motor local. O
# cliente sobe o vídeo, o servidor manda pro vmake Smart e devolve o MP4
# limpo (re-hospedado, sem marca do motor).
#
# AUTH: header `Access-Token` (NÃO Bearer). Pegue do browser logado em
# https://vmake.ai/video-watermark-remover/editor:
#   DevTools > Application > Local Storage > vmake.ai >
#     vmake-auth-store  → data.state.accessToken   (cola em VMAKE_ACCESS_TOKEN)
# O token expira (~2 meses); quando cair, renove logando de novo e recopiando.
VMAKE_ACCESS_TOKEN=
# X-Gid = só tracking do Meitu, NÃO é validado (gid vazio/aleatório passa).
# OPCIONAL — só preencha se quiser; tem default genérico no código:
# VMAKE_GID=
# Opcional (default GMT+00:00):
# VMAKE_TIMEZONE=GMT-03:00
#
# >>> ANTI-BLOQUEIO (em produção / Vercel) <<<
# A Vercel sai por MUITOS IPs. 1 token batendo de N IPs parece conta
# compartilhada e arrisca bloqueio. Roteie TODAS as chamadas vmake por UM
# proxy de IP FIXO (HTTP CONNECT). Ex: http://user:pass@ip:porta
# VMAKE_PROXY_URL=
# Ritmo humano (fila serial por instância):
# VMAKE_CONCURRENCY=2
# VMAKE_MIN_GAP_MS=800
