{
  "manifest_version": 3,
  "name": "HeyGen Automator",
  "version": "1.0.0",
  "description": "Gera videos em lote no HeyGen a partir de audios. Avatar III, IV e V com paralelismo de ate 5 jobs. Nao oficial — feito por @euojeff.daily.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*.heygen.com/*",
    "https://*.heygen.ai/*",
    "https://heygen-resources-prod.s3-accelerate.amazonaws.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "HeyGen Automator",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.heygen.com/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
