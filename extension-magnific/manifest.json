{
  "manifest_version": 3,
  "name": "DARKO LAB — Magnific Auto",
  "version": "3.5.54",
  "description": "DARKO LAB Magnific Auto v3.5.44 — EDGE-GUARANTEED + BACKGROUND. (1) createVideoGenNodeViaOutputHandle verifica edge por contagem; se video nasceu solto, deleta órfão e refaz até 3x — NUNCA gera video sem linha da imagem. (2) Removido TODO roubo de foco (findOrCreateMagnificTab + re-focus periódico): Magnific roda 100% em background, aba nunca é trazida pro foco. Mantém v3.5.41 (3 settles Kling) + CREDIT-PREVIEW GATE + MODEL_GUARD + USERSNAP SHIM + force_credits:false. Zero-crédito intacto.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "debugger"
  ],
  "host_permissions": [
    "https://www.magnific.com/*",
    "https://magnific.com/*",
    "https://*.magnific.com/*",
    "https://*.freepik.com/*",
    "https://*.pikaso.cdnpk.net/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "usersnap-shim.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "magnific-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DARKO LAB Magnific Auto",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
