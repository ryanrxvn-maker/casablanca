{
  "manifest_version": 3,
  "name": "DARKO LAB — Magnific Auto",
  "version": "3.3.2",
  "description": "DARKO LAB Magnific Auto v3.3.2 — FIX CRITICO: handleForward agora envolve TUDO em try/catch (findOrCreateMagnificTab, waitForTabComplete, ensureContentLoaded) — antes ensureContentLoaded throw virava unhandled rejection e user via stall mudo. + Heartbeat 60s pro primeiro progress (se content script nao iniciar, ABORTA com erro claro + instrucao 'F5 na aba Magnific'). + Retry exponencial fetchJson 504/timeout + tab routing inteligente + LOCK Kling 2.5.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.magnific.com/*",
    "https://magnific.com/*",
    "https://*.magnific.com/*",
    "https://*.freepik.com/*",
    "https://*.pikaso.cdnpk.net/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "magnific-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DARKO LAB Magnific Auto",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
