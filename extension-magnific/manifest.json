{
  "manifest_version": 3,
  "name": "DARKO LAB — Magnific Auto",
  "version": "3.4.0",
  "description": "DARKO LAB Magnific Auto v3.4.0 — SIMPLIFICADO: removida complexidade LOCK retry/verify/pre-execute que travava pipeline (user reportou 'antes funcionava'). Mantido: selectModelInNode STRICT equality match (era o fix real do bug Seedance). Mantido: tab routing inteligente + retry fetchJson 504 + heartbeat + total try/catch. Pipeline volta ao fluxo simples Phase 1→5 sem overhead de verifies.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.magnific.com/*",
    "https://magnific.com/*",
    "https://*.magnific.com/*",
    "https://*.freepik.com/*",
    "https://*.pikaso.cdnpk.net/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "magnific-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DARKO LAB Magnific Auto",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
