{
  "manifest_version": 3,
  "name": "DARKO LAB — Magnific Auto",
  "version": "2.0.0",
  "description": "DARKO LAB Magnific Auto v2.0 — endpoints REAIS mapeados via reverse-engineering. POST /app/api/spaces/{id}/workflows/execute + DOM automation pra criar nodes (Image Generator + Video Generator Kling 2.5/2.6). Premium+ obrigatorio.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.magnific.com/*",
    "https://magnific.com/*",
    "https://*.magnific.com/*",
    "https://*.freepik.com/*",
    "https://*.pikaso.cdnpk.net/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "magnific-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DARKO LAB Magnific Auto",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
