{
  "manifest_version": 3,
  "name": "DARKO LAB — Magnific Auto",
  "version": "3.5.40",
  "description": "DARKO LAB Magnific Auto v3.5.40 — CREDIT-PREVIEW GATE definitivo. scanCreditCostPreview() roda ANTES de cada executeWorkflow (imagem E vídeo): lê UI do node e ABORTA se detectar QUALQUER preview de custo em créditos (só dispara se Unlimited/sem-custo). Camadas mantidas: USERSNAP SHIM main-world (v3.5.38) + MODEL_GUARD Kling 2.5 estrito + resolução 720p/1K LOD-tolerante + EDGE non-fatal + force_credits:false. Garantia máxima zero-crédito: na dúvida ABORTA, nunca dispara com custo.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "debugger"
  ],
  "host_permissions": [
    "https://www.magnific.com/*",
    "https://magnific.com/*",
    "https://*.magnific.com/*",
    "https://*.freepik.com/*",
    "https://*.pikaso.cdnpk.net/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "usersnap-shim.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "magnific-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DARKO LAB Magnific Auto",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
