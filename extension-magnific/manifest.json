{
  "manifest_version": 3,
  "name": "DARKO LAB — Magnific Auto",
  "version": "3.3.1",
  "description": "DARKO LAB Magnific Auto v3.3.1 — ROBUSTEZ: (1) findOrCreateMagnificTab prefere TAB ATIVO (foco) + multi-tier ranking, evita rotear pra tab CDP-controlled. (2) ensureContentLoaded faz double-PING + chrome.scripting.executeScript + verify pos-inject — se falhar, erro CLARO ao inves de stall mudo. (3) fetchJson retry exponencial em 502/503/504/429/timeout (Magnific instavel em horario de pico). + Template auto-builder + LOCK Kling 2.5.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.magnific.com/*",
    "https://magnific.com/*",
    "https://*.magnific.com/*",
    "https://*.freepik.com/*",
    "https://*.pikaso.cdnpk.net/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "magnific-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DARKO LAB Magnific Auto",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
