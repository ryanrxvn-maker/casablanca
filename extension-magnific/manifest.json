{
  "manifest_version": 3,
  "name": "DARKO LAB — Magnific Auto",
  "version": "3.2.0",
  "description": "DARKO LAB Magnific Auto v3.2.0 — TEMPLATE SPACE: duplica space pre-criado com N pares Kling 2.5 LOCK + atribui prompts + dispara. Pula fase node-creation (race condition Seedance) inteira. + KLING 2.5 LOCK (v3.1.7): verifica modelo/aspect/quality/duration, retry 3x, ABORTA batch se config errada. Endpoints descobertos live: POST /spaces/{id}/duplicate, PUT /spaces/{id}.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.magnific.com/*",
    "https://magnific.com/*",
    "https://*.magnific.com/*",
    "https://*.freepik.com/*",
    "https://*.pikaso.cdnpk.net/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "magnific-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DARKO LAB Magnific Auto",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
