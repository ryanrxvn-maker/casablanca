{
  "manifest_version": 3,
  "name": "DARKO LAB — Magnific Auto",
  "version": "3.2.3",
  "description": "DARKO LAB Magnific Auto v3.2.3 — FIX descoberto live: aspect 'Auto' (inherit-from-input) e VALIDO quando input image gen e 9:16. 'Auto' removido de FORBIDDEN_VIDEO_MODELS (e botao de aspect, nao nome de modelo). LOCK aspect aceita '9:16' OR 'Auto'. Provado com node real (Kling 2.5 + 720p + 10s + Auto-aspect → 716x1284 output 9:16).",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.magnific.com/*",
    "https://magnific.com/*",
    "https://*.magnific.com/*",
    "https://*.freepik.com/*",
    "https://*.pikaso.cdnpk.net/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.magnific.com/*",
        "https://magnific.com/*"
      ],
      "js": [
        "magnific-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DARKO LAB Magnific Auto",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
