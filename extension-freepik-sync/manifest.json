{
  "manifest_version": 3,
  "name": "Auto Edit · Freepik Sync",
  "version": "1.0.4",
  "description": "Sincroniza sua conta Freepik/Magnific com Auto Edit. Zero copy-paste — fica logado, fica conectado.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.magnific.com/*",
    "https://magnific.com/*",
    "https://*.magnific.com/*",
    "https://*.freepik.com/*",
    "https://*.vercel.app/*",
    "https://*.auto-edit.com.br/*",
    "https://*.auto-edit.com/*",
    "https://auto-edit.com.br/*",
    "https://auto-edit.com/*",
    "http://localhost/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "https://*.auto-edit.com.br/*",
        "https://*.auto-edit.com/*",
        "https://auto-edit.com.br/*",
        "https://auto-edit.com/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": ["app-discover.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Auto Edit · Freepik Sync",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
